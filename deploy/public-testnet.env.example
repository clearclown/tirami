# Copy to /etc/tirami/public-testnet.env and chmod 600.
#
# Generate with:
#   openssl rand -hex 32
TIRAMI_API_TOKEN=replace-with-32-byte-random-hex

# Comma-separated PUBLIC_KEY or PUBLIC_KEY@RELAY_URL entries.
TIRAMI_BOOTSTRAP_PEERS=<seed-a-public-key>@https://relay.example.com,<seed-b-public-key>@https://relay.example.com

# Public participants should normally keep the HTTP API local and let
# P2P carry mesh traffic. For a private Tailscale lab that wants agent
# HTTP dispatch, set this to the machine's concrete 100.x address so
# the node can advertise a reachable PriceSignal.http_endpoint. Set
# 0.0.0.0 only if you intentionally expose the HTTP API behind TLS/WAF
# and keep TIRAMI_API_TOKEN set.
TIRAMI_BIND=127.0.0.1
TIRAMI_PORT=3000

# Stable P2P UDP socket used for direct bootstrap join strings such as
# PUBLIC_KEY@100.83.54.6:7700. Use the same port on every machine.
TIRAMI_P2P_BIND=0.0.0.0:7700

TIRAMI_MODEL=qwen2.5:0.5b

RUST_LOG=info,swarm_discovery=error,iroh::socket::transports::relay=error,iroh::socket::remote_map::remote_state=error,iroh_relay=error,noq_udp=error
